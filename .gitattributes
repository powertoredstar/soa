# 统一换行符，减少 Windows 下 LF/CRLF 警告
* text=auto

# 源码与文档统一使用 LF
*.java text eol=lf
*.jsp text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.gitignore text eol=lf

# 二进制文件不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.class binary
